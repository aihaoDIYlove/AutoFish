<Window x:Class="AutoFish.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoFish 设置"
        Width="520" Height="620"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Topmost="True"
        Background="Transparent">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="Transparent" CornerRadius="3">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Background="#48484A" Width="6">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="3"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EBEBF5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="SubText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#98989D"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="#EBEBF5"/>
            <Setter Property="BorderBrush" Value="#48484A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CaretBrush" Value="#0A84FF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="#EBEBF5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EBEBF5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True"
                                      Background="#1C1C1E" Margin="0,0,0,0"/>
                            <Border Grid.Row="1" Background="Transparent">
                                <ContentPresenter ContentSource="SelectedContent"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#98989D"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}"
                                Cursor="Hand">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="BorderBrush" Value="#0A84FF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#EBEBF5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RodSlotCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EBEBF5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Background="#E81C1C1E"
            BorderBrush="#3A3A3C" BorderThickness="1" Margin="4">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#2C2C2E" CornerRadius="16,16,0,0"
                    Padding="20,14" MouseLeftButtonDown="TitleBar_Drag">
                <Grid>
                    <TextBlock Text="设置" FontSize="17" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                    <Button Content="✕" Width="30" Height="30" HorizontalAlignment="Right"
                            Background="Transparent" Foreground="#888" BorderBrush="Transparent"
                            FontSize="15" Click="BtnCancel_Click"/>
                </Grid>
            </Border>

            <TabControl x:Name="SettingsTabs" Grid.Row="1" Margin="20,8,20,0"
            SelectionChanged="SettingsTabs_SelectionChanged">
                <TabItem Header="通用">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,0,14">
                        <StackPanel>

                    <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeaderText}" Text="OCR 截图区域"/>
                            <TextBlock Style="{StaticResource SubText}" Text="屏幕坐标，像素值" Margin="0,-6,0,10"/>

                            <Grid HorizontalAlignment="Left">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="38"/>
                                    <RowDefinition Height="38"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="X" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCaptureX" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                <TextBlock Text="Y" Grid.Column="3" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCaptureY" Grid.Column="4" Width="90" VerticalAlignment="Center"/>

                                <TextBlock Text="宽" Grid.Row="1" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCaptureW" Grid.Row="1" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                <TextBlock Text="高" Grid.Row="1" Grid.Column="3" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCaptureH" Grid.Row="1" Grid.Column="4" Width="90" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeaderText}" Text="检测"/>
                            <TextBlock Text="轮询间隔" Margin="0,0,0,6"/>
                            <StackPanel Margin="0,0,0,6">
                                <RadioButton x:Name="Rb400" GroupName="Polling" Content="400ms — 极低开销，概率失败"/>
                                <RadioButton x:Name="Rb330" GroupName="Polling" Content="330ms — 低开销，可用"/>
                                <RadioButton x:Name="Rb250" GroupName="Polling" Content="250ms — 均衡，推荐"/>
                                <RadioButton x:Name="Rb200" GroupName="Polling" Content="200ms — 性能档"/>
                                <RadioButton x:Name="Rb125" GroupName="Polling" Content="125ms — 高开销，不推荐"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkAutoFish" Content="启用自动钓鱼"/>
                            <CheckBox x:Name="ChkDebugLog" Content="调试日志：OCR 结果写入 log.txt"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeaderText}" Text="识别短语"/>
                            <TextBlock Style="{StaticResource SubText}" Text="逗号分隔多个短语" Margin="0,-6,0,8"/>

                            <TextBlock Text="抛竿短语" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtCastPhrases" Height="40" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="咬钩短语" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtBitePhrases" Height="40" TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="收回短语" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtReelPhrases" Height="40" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Style="{StaticResource HeaderText}" Text="延迟设置 (ms)"/>

                            <Grid HorizontalAlignment="Left" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="38"/>
                                    <RowDefinition Height="38"/>
                                    <RowDefinition Height="38"/>
                                    <RowDefinition Height="38"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="抛竿后冷却" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCastCooldown" Grid.Column="1" Width="90" VerticalAlignment="Center"/>

                                <TextBlock Text="收回后重抛" Grid.Row="1" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtRecastDelay" Grid.Row="1" Grid.Column="1" Width="90" VerticalAlignment="Center"/>

                                <TextBlock Text="右键持续" Grid.Row="2" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtClickDuration" Grid.Row="2" Grid.Column="1" Width="90" VerticalAlignment="Center"/>

                                <TextBlock Text="咬钩防连点" Grid.Row="3" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtHookCooldown" Grid.Row="3" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="更换鱼竿">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,4,0,14">
                        <StackPanel>

                            <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource HeaderText}" Text="自动切换鱼竿"/>
                                    <CheckBox x:Name="ChkAutoSwitchRod" Content="启用自动切换鱼竿" Margin="0,0,0,10"/>

                                    <Grid HorizontalAlignment="Left" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="38"/>
                                            <RowDefinition Height="38"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="切杆延迟 (ms)" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtSwitchRodDelay" Grid.Column="1" Width="90" VerticalAlignment="Center"/>

                                        <TextBlock Text="切杆重抛 (ms)" Grid.Row="1" VerticalAlignment="Center"/>
                                        <TextBox x:Name="TxtSwitchRodRecast" Grid.Row="1" Grid.Column="1" Width="90" VerticalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource HeaderText}" Text="鱼竿配置"/>
                                    <TextBlock Style="{StaticResource SubText}" Text="勾选启用的格子（1=最左，9=最右）" Margin="0,-6,0,10"/>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <CheckBox x:Name="ChkRod1" Content="1" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod2" Content="2" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod3" Content="3" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod4" Content="4" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod5" Content="5" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod6" Content="6" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod7" Content="7" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod8" Content="8" Style="{StaticResource RodSlotCheckBox}"/>
                                        <CheckBox x:Name="ChkRod9" Content="9" Style="{StaticResource RodSlotCheckBox}"/>
                                    </StackPanel>

                                    <TextBlock Style="{StaticResource SubText}"
                                               Text="⚠ 请确保手持最左侧启用的鱼竿进行首次抛竿"
                                               Margin="0,14,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource HeaderText}" Text="损坏识别短语"/>
                                    <TextBlock Style="{StaticResource SubText}" Text="逗号分隔多个短语" Margin="0,-6,0,8"/>
                                    <TextBox x:Name="TxtBrokenPhrases" Height="40" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#2C2C2E" CornerRadius="12" Padding="20" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource HeaderText}" Text="调试"/>
                                    <CheckBox x:Name="ChkDebugLogInput"
                                              Content="调试日志：输入事件及切杆决策写入 log.txt"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Background="#2C2C2E" CornerRadius="0,0,16,16" Padding="20,14">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="取消"
                            Background="Transparent" Foreground="#98989D" BorderBrush="#48484A"
                            Width="80" Height="40" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                    <Button x:Name="BtnSave" Content="保存"
                            Background="#0A84FF" Foreground="#FFFFFF" BorderBrush="Transparent"
                            Width="80" Height="40" Click="BtnSave_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
