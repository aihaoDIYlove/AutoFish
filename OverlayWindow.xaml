<Window x:Class="AutoFish.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Cursor="Cross"
        Title="AutoFish">

    <Grid x:Name="RootGrid">
        <!-- 遮罩层：半透明黑底 + 选区镂空 -->
        <Path x:Name="OverlayPath"
              Fill="#44000000" Stroke="{x:Null}" />

        <!-- 选区边框 -->
        <Path x:Name="SelectionBorder"
              Stroke="#00FF88" StrokeThickness="2"
              StrokeDashArray="6,3" Fill="Transparent" />

        <!-- 四角拖拽手柄 -->
        <Border x:Name="HandleNW" Width="10" Height="10"
                Background="#00FF88" CornerRadius="2"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed" Cursor="SizeNWSE"
                MouseLeftButtonDown="Handle_MouseDown"/>
        <Border x:Name="HandleNE" Width="10" Height="10"
                Background="#00FF88" CornerRadius="2"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed" Cursor="SizeNESW"
                MouseLeftButtonDown="Handle_MouseDown"/>
        <Border x:Name="HandleSW" Width="10" Height="10"
                Background="#00FF88" CornerRadius="2"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed" Cursor="SizeNESW"
                MouseLeftButtonDown="Handle_MouseDown"/>
        <Border x:Name="HandleSE" Width="10" Height="10"
                Background="#00FF88" CornerRadius="2"
                HorizontalAlignment="Left" VerticalAlignment="Top"
                Visibility="Collapsed" Cursor="SizeNWSE"
                MouseLeftButtonDown="Handle_MouseDown"/>

        <!-- 确认按钮（调整时显示） -->
        <Border x:Name="ConfirmLabel"
                Background="#CC1A1A35" CornerRadius="6"
                Padding="12,6" HorizontalAlignment="Left"
                VerticalAlignment="Top" Visibility="Collapsed"
                Cursor="Hand" MouseLeftButtonDown="Confirm_Click">
            <TextBlock Text="✓ 确认 (Enter)" Foreground="#00FF88"
                       FontSize="12" FontFamily="Segoe UI"/>
        </Border>

        <!-- 尺寸标签 -->
        <Border x:Name="SizeLabel"
                Background="#CC1E1E1E" CornerRadius="4"
                Padding="6,3" HorizontalAlignment="Left"
                VerticalAlignment="Top" Visibility="Collapsed">
            <TextBlock x:Name="SizeLabelText"
                       Foreground="#00FF88" FontSize="12" FontFamily="Segoe UI"/>
        </Border>

        <!-- OCR 调试面板 -->
        <Border x:Name="DebugPanel"
                Background="#CC0A0A1A" CornerRadius="6"
                Padding="8,4" HorizontalAlignment="Left"
                VerticalAlignment="Top" Margin="16,16,0,0"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="DebugState" Foreground="#88CC88"
                           FontSize="11" FontFamily="Segoe UI"/>
                <TextBlock x:Name="DebugText" Foreground="#8888CC"
                           FontSize="12" FontFamily="Segoe UI" Text="等待检测..."/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
